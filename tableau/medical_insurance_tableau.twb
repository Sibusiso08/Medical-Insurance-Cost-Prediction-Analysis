          </datasources>
          <datasource-dependencies datasource='federated.1tgbh72136eqzd11rrc8m03lw66y'>
            <column caption='BMI Category' datatype='string' name='[Calculation_0591043999141889]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [body_mass_value (bmi)] &lt; 18.5 THEN &quot;Underweight&quot;&#13;&#10;ELSEIF [body_mass_value (bmi)] &gt;= 18.5 AND [body_mass_value (bmi)] &lt;= 24.9 THEN &quot;Normal&quot;&#13;&#10;ELSEIF [body_mass_value (bmi)] &gt;= 25 AND [body_mass_value (bmi)] &lt;= 29.9 THEN &quot;Overweight&quot;&#13;&#10;ELSE &quot;Obese&quot;&#13;&#10;END' />
            </column>
            <column caption='Annual Medical Cost' datatype='real' name='[annual_medical_cost]' role='measure' type='quantitative' />
            <column-instance column='[annual_medical_cost]' derivation='Avg' name='[avg:annual_medical_cost:qk]' pivot='key' type='quantitative' />
